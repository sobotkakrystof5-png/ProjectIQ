# Neon — PostgreSQL připojení
DATABASE_URL=postgresql://...

# NextAuth
NEXTAUTH_SECRET=                  # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Veřejná URL aplikace — používá se v klientských linkech (/p/token)
# Nastav na produkční doménu: https://zakaziq.cz
NEXT_PUBLIC_APP_URL=https://zakaziq.cz

# Admin přihlášení
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=              # node -e "require('bcryptjs').hash('heslo',12).then(console.log)"

# Gmail SMTP — emailová brána (nodemailer)
GMAIL_USER=tvuj@gmail.com
GMAIL_APP_PASSWORD=                # App password z Google Account → Security → App passwords

# Kontakt admin (pro WhatsApp a hovorové konzultace)
ADMIN_PHONE=420601234567          # Bez mezery, bez +

# Meeting linky (vyplň pevné linky pro Teams/Meet místnosti)
GOOGLE_MEET_LINK=https://meet.google.com/xxx-yyyy-zzz
TEAMS_MEETING_LINK=https://teams.microsoft.com/l/meetup-join/...

# Veřejný booking API (app/api/public/booking) — pro integraci s vizeon.cz
VIZEON_API_KEY=                   # node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Cron zabezpečení — Vercel posílá tento token v Authorization hlavičce při spuštění cron jobu
CRON_SECRET=                      # node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
